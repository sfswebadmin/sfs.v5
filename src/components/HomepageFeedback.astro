---
const { ratingsTotal } = Astro.props;
const { attendance, 
        returns, 
        excellent, 
        good, 
        average, 
        disappointing, 
        awful, 
        ratingsAverage } = ratingsTotal;
---
    <section class="home-feedback-grid">
        <div></div>
        <div>
            <h3>Overall Audience Feedback</h3>
            <p>
                The table below represents the audience feedback, for all films
                shown to date.
            </p>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Attendance</th>
                            <th>Returns</th>
                            <th>5 <i class="fa fa-star" aria-hidden="true"></i></th>
                            <th>4 <i class="fa fa-star" aria-hidden="true"></i></th>
                            <th>3 <i class="fa fa-star" aria-hidden="true"></i></th>
                            <th>2 <i class="fa fa-star" aria-hidden="true"></i></th>
                            <th>1 <i class="fa fa-star" aria-hidden="true"></i></th>
                            <th>Average</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>{attendance}</td>
                            <td>{returns}</td>
                            <td>{excellent}</td>
                            <td>{good}</td>
                            <td>{average}</td>
                            <td>{disappointing}</td>
                            <td>{awful}</td>
                            <td>{ratingsAverage != null ? '' + ratingsAverage + '%' : ''}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>